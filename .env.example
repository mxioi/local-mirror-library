# Optional overrides for config/app.yaml
ARCHIVE_HOST=0.0.0.0
ARCHIVE_PORT=8010
ARCHIVE_LIBRARY_PORT=8080
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Paths
ARCHIVE_DB_PATH=wikipedia-local/library.db
ARCHIVE_CONFIG_PATH=wikipedia-pages.json
ARCHIVE_MANIFEST_PATH=wikipedia-local/manifest.json
ARCHIVE_OUTPUT_ROOT=wikipedia-local
ARCHIVE_LOG_PATH=wikipedia-local/archive.log

# Auth
ARCHIVE_ADMIN_PASSWORD=
ARCHIVE_SESSION_HOURS=12
AD_SERVER=ad.example.local
AD_DOMAIN=example.local
AD_USE_SSL=0

# Limits
MAX_JOBS_AGE_DAYS=30
MAX_DB_SIZE_MB=500
